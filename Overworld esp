local function createVisual(rootPart, model, typ, customName)
    local addr = model.Address
    trackedAddrs[addr] = true
    

    local function getChar()
        local LocalPlayer = Players.LocalPlayer
        local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
        return HumanoidRootPart, LocalPlayer, Character
    end



    local esp = {
        Label = Drawing.new("Text"),
        Object = rootPart,
        Model = model,
        Name = customName or model.Name,
        Type = typ
    }
    esp.Label.Size = cfg.settings.textSize
    esp.Label.Center = true 
    esp.Label.Outline = cfg.settings.textOutline 
    esp.Label.ZIndex = 120 
    esp.Label.Font = Drawing.Fonts.Fortnite
    esp.Label.Visible = false
    return esp
end



local function isTrackingStr(model)
    local addr = nil
    pcall(function() addr = model.Address end)
    return addr and trackedAddrs[addr] == true
end
local function getPartFromPath(model, pathStr)
    if not string.find(pathStr, "/") then
        return model:FindFirstChild(pathStr)
    end
    local parts = string.split(pathStr, "/")
    local current = model
    for _, name in ipairs(parts) do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    return current
end




local function updateScanners()
    local containersFolder = Workspace:FindFirstChild("Containers")
    if not containersFolder then return end
    for _, cityFolder in ipairs(containersFolder:GetChildren()) do
        for _, model in ipairs(cityFolder:GetChildren()) do
            for _, def in ipairs(itemDefs) do
                if model.Name == def.ModelName then
                    if cfg.world[def.ConfigKey].enabled then
                        local targetPart = getPartFromPath(model, def.PartPath)
                        if targetPart and not isTrackingStr(model) then
                            table.insert(espList, createVisual(targetPart, model, def.Name, def.Name))
                        end
                    end
                end
            end
        end
    end
end





local function updateVisuals()
    local camObj = Workspace.CurrentCamera
    if not camObj then return end
    local camPos = camObj.Position
    local maxDist = cfg.settings.maxDistance

    for i = #espList, 1, -1 do
        local v = espList[i]
        local cCfg = typeToCfg[v.Type]
        local cObj = v.Object
        local model = v.Model

        if not cObj or not model or not cObj.Parent or not model.Parent or not cCfg.enabled then
            pcall(function()
                local addr = (model and model.Address)
                if addr then trackedAddrs[addr] = nil end
                v.Label:Remove()
            end)
            table.remove(espList, i)
        else
            local pos = cObj.Position
            local sPos, onScreen = worldToScreen(pos)
            local dist = (pos - camPos).Magnitude
            
            if onScreen and dist <= maxDist then
                local size = 3500 / dist
                local x, y = sPos.X, sPos.Y
                local hs = size / 2
                local clr = cCfg.color

                if cCfg.name or cCfg.dist then
                    local txt = ""
                    if cCfg.name then txt = v.Name end
                    if cCfg.dist then txt = txt .. (txt ~= "" and " " or "") .. "[" .. math.floor(dist) .. "m]" end
                    v.Label.Text = txt
                    v.Label.Position = Vector2.new(x, y + hs + 5)
                    v.Label.Color = clr
                    
                    local finalSize = cfg.settings.textSize
                    if cfg.settings.dynamicSize then
                        local add = (1 - math.min(dist / maxDist, 1)) * cfg.settings.dynamicScale
                        finalSize = math.clamp(finalSize + add, 1, 100)
                    end
                    v.Label.Size = finalSize
                    v.Label.Outline = cfg.settings.textOutline
                    v.Label.Visible = true
                else
                    v.Label.Visible = false
                end
            else
                if v.Label.Visible then
                    v.Label.Visible = false
                end
            end
        end
    end
end




