local function formatBm(msg, targetPlayer)
    local name = targetPlayer and targetPlayer.Name or "Kid"
    local dist = "0"
    if targetPlayer then
        local lp = game:GetService("Players").LocalPlayer
        local char = lp.Character
        local tChar = targetPlayer.Character
        if char and tChar and char:FindFirstChild("HumanoidRootPart") and tChar:FindFirstChild("HumanoidRootPart") then
            dist = tostring(math.floor((char.HumanoidRootPart.Position - tChar.HumanoidRootPart.Position).Magnitude))
        end
    end
    
    local formatted = msg:gsub("{name}", name):gsub("{dist}", dist)
    return formatted
end

local function sendBmMessage(target)
    local list = bmMessages[bmCfg.textType] or bmMessages["Inertia"]
    local rawMsg = list[math.random(1, #list)]
    local finalMsg = formatBm(rawMsg, target)
    sendChatMessage(finalMsg)
end

