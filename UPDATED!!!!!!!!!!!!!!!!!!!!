local function getPlanarSpeed(part)
    if not part then return 0 end
    local vel = part.AssemblyLinearVelocity or part.Velocity
    local vx = vel.X or vel.x or 0
    local vz = vel.Z or vel.z or 0
    return math.sqrt((vx * vx) + (vz * vz))
end
local function getVectorXZ(vec)
    if not vec then
        return 0, 0
    end
    return vec.X or vec.x or 0, vec.Z or vec.z or 0
end
local function normalizeXZ(x, z)
    local len = math.sqrt((x * x) + (z * z))
    if len <= 0.001 then
        return 0, 0, 0
    end
    return x / len, z / len, len
end
local function getMemoryCameraBasisXZ()
    local yaw = getCamLookYaw()
    local forwardX = -math.sin(yaw)
    local forwardZ = -math.cos(yaw)
    local rightX = math.cos(yaw)
    local rightZ = -math.sin(yaw)
    return forwardX, forwardZ, rightX, rightZ
end
