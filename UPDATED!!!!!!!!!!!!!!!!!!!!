                        local h = (u1 / (math.pi * 2) - offset) % 1
                        if h < 0 then h = h + 1 end
                        hColor = Color3.fromHSV(h, 1, 1)
                    end
                    
                    for j = 0, vSegs - 1 do
                        local v1 = (j / vSegs) * math.pi * 2
                        local v2 = ((j + 1) / vSegs) * math.pi * 2
                        
                        local p1, n1 = getTorusPtAndNorm(u1, v1)
                        local p2, n2 = getTorusPtAndNorm(u2, v1)
                        local p3, n3 = getTorusPtAndNorm(u1, v2)
                        local p4, n4 = getTorusPtAndNorm(u2, v2)
                        
                        local trisData = { {p1, p2, p3, n1}, {p3, p2, p4, n4} }
                        
                        for _, tD in ipairs(trisData) do
                            local pa, pb, pc, pNorm = tD[1], tD[2], tD[3], tD[4]
                            
                            local sA, visA = WorldToScreen(pa)
                            local sB, visB = WorldToScreen(pb)
                            local sC, visC = WorldToScreen(pc)
                            
                            if visA and visB and visC then
                                local cross2D = (sB.X - sA.X) * (sC.Y - sA.Y) - (sB.Y - sA.Y) * (sC.X - sA.X)
                                
