                local cam = workspace.CurrentCamera
                if cam then
                    local target = isAimingFov and 70 or cfg.misc.fovValue
                    pcall(function() 
                        if cam.FieldOfView ~= target then
                            cam.FieldOfView = target 
                        end
                    end)
                end
            end
            
            if cfg.spinner.enabled then
                local hrpPrim = getPrimitive(hrp)
                if hrpPrim then
                    local sRad = 0
                    if cfg.spinner.randomAngles then
                        sRad = math.rad(math.random(0, 360))
                    else
                        spinAngle = (spinAngle + (cfg.spinner.spinSpeed / 100) * 5000 * dt) % 360
                        sRad = math.rad(spinAngle)
                    end
                    local pitch = cfg.misc.flipEnabled and math.pi or 0
                    setPitchYaw(hrpPrim, pitch, sRad)
                end
                return
            end
            if not cfg.player.enabled then
                if cfg.misc.flipEnabled then
                    local hrpPrim = getPrimitive(hrp)
                    if hrpPrim then
                        setPitchYaw(hrpPrim, math.pi, getCamLookYaw())
                    end
                end
                return
            end
            if cfg.player.targetMode ~= "None" then
                refreshTarget()
            else
                targetPlayer = nil
            end
            local myPos = hrp.Position
            local baseYaw = getCamLookYaw()
            if cfg.player.targetMode ~= "None" and targetPlayer then
                local tHRP = getHRP(targetPlayer)
                if tHRP then
                    local d = tHRP.Position - myPos
                    baseYaw = math.atan2(-d.X, d.Z)
                end
            end
            pcall(updateIndicators)
            local finalYaw = baseYaw
            local manualsActive = cfg.player.manualsEnabled and cfg.player.manualDirection ~= "None"
            if manualsActive then
                if cfg.player.manualDirection == "Left" then
                    finalYaw = finalYaw + math.rad(cfg.player.leftYaw)
                elseif cfg.player.manualDirection == "Right" then
                    finalYaw = finalYaw + math.rad(cfg.player.rightYaw)
                end
            end
            local modeYaw = 0
            if cfg.player.yawMode == "Static" then
                modeYaw = cfg.player.yawValue
            elseif cfg.player.yawMode == "Spin" then
                spinAngleActive = (spinAngleActive + (100 * dt * 5)) % 360
                modeYaw = spinAngleActive
            elseif cfg.player.yawMode == "Sway" then
                modeYaw = math.sin(now * cfg.player.swaySpeed) * cfg.player.swayRange
            end
            finalYaw = finalYaw + math.rad(modeYaw)
            local canJitter = true
            if (cfg.player.yawMode == "Sway" or cfg.player.yawMode == "Spin") and not manualsActive then
                canJitter = false
            end
            if cfg.player.jitterEnabled and canJitter then
                local speed = math.max(0.1, cfg.player.jitterSpeed)
                local jitterInterval = 1 / speed
                if now - lastJitterTime >= jitterInterval then
                    lastJitterTime = now
                    jitterState = not jitterState
                    local halfAngle = cfg.player.jitterValue / 2
                    if cfg.player.jitterRandom then
                        currentJitterOffset = (math.random() * cfg.player.jitterValue) - halfAngle
                    else
                        currentJitterOffset = jitterState and halfAngle or -halfAngle
                    end
                end
                finalYaw = finalYaw + math.rad(currentJitterOffset)
            end
            if cfg.player.bodyYaw == "Static" then
                finalYaw = finalYaw + math.rad(cfg.player.bodyYawValue)
            elseif cfg.player.bodyYaw == "Opposite" then
                finalYaw = finalYaw + math.pi
            end
            local hrpPrim = getPrimitive(hrp)
            if hrpPrim then
                local pitch = cfg.misc.flipEnabled and math.pi or 0
                setPitchYaw(hrpPrim, pitch, finalYaw)
            end
        end)
        if not success then
            warn("[Anti-Aim Error]", tostring(err))
            print("[Anti-Aim Error]", tostring(err))
        end
    end
end)
