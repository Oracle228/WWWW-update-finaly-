local function lerpVector(v1, v2, t)
    return Vector3.new(
        v1.X + (v2.X - v1.X) * t,
        v1.Y + (v2.Y - v1.Y) * t,
        v1.Z + (v2.Z - v1.Z) * t
    )
end
