                                local e2 = root + Vector3.new(rx*math.cos(aT)*fL*0.6, math.sin(aT+lF*0.5)*fL*0.6, rz*math.cos(aT)*fL*0.6)
                                local alpha, oAlpha = cfg.wings.opacity/100 * (0.6+t0*0.4), cfg.wings.outlineOpacity/100
                                drawWingTri(root, e1, tip, alpha, oAlpha) ; drawWingTri(root, tip, e2, alpha, oAlpha)
                            end
                        elseif cfg.wings.style == "Demon" then
                            local flap = flapAngle * sgn
                            local sAngles = {}
                            for i = 1, numFeathers do sAngles[i] = math.pi*0.05 + (i/numFeathers)*math.pi*0.4 + math.sin(i*7.3)*0.15 end
                            for i, ang in ipairs(sAngles) do
                                local t0 = i/numFeathers
                                local sL, sW = sz*(0.7+math.sin(i*2.1)*0.45), sz*0.07
                                local tip = root + Vector3.new(rx*math.cos(ang)*sL, math.sin(ang)*sL+flap*t0*1.2, rz*math.cos(ang)*sL)
                                local bXn, bZn = rz*sW, -rx*sW
                                local eA, eB = root+Vector3.new(bXn, 0.15, bZn), root+Vector3.new(-bXn, -0.15, -bZn)
                                local alpha, oAlpha = cfg.wings.opacity/100, cfg.wings.outlineOpacity/100
                                drawWingTri(eA, tip, eB, alpha, oAlpha)
                                if i > 1 then
                                    local pa, pl = sAngles[i-1], sz*(0.7+math.sin((i-1)*2.1)*0.45)
                                    local pTip = root+Vector3.new(rx*math.cos(pa)*pl, math.sin(pa)*pl+flap*((i-1)/numFeathers)*1.2, rz*math.cos(pa)*pl)
                                    drawWingTri(root, pTip, tip, alpha*0.45, oAlpha*0.6)
                                end
                            end
                        end
                    end
                    makeWing(1) ; makeWing(-1)
                    for k = wTri, #localWings.filled do
                        if localWings.filled[k] then localWings.filled[k].Visible = false ; localWings.outline[k].Visible = false end
                    end
                end
            end
            
        end)
        if not success then
        end
    end
end)
