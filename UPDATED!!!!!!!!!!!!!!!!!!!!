local function getBunnyHopWishDir(humanoid)
    local forward, side = getMovementInputAxes()
    if forward == 0 and side == 0 then
        return 0, 0, 0
    end


    local cam = workspace.CurrentCamera
    local camAddr = (cam and cam.Address) or 0
    if camAddr == 0 then return 0, 0, 0 end

    local bx = memory_read("float", camAddr + 0xF8 + 0x18)
    local bz = memory_read("float", camAddr + 0xF8 + 0x20)
    

    local lx, lz = bx, -bz
    local rx, rz = bz, bx
    
    local lookLen = math.sqrt(lx*lx + lz*lz)
    local rightLen = math.sqrt(rx*rx + rz*rz)
    if lookLen > 0 then lx, lz = lx/lookLen, lz/lookLen end
    if rightLen > 0 then rx, rz = rx/rightLen, rz/rightLen end

    local wishX = (lx * forward) + (rx * side)
    local wishZ = (lz * forward) + (rz * side)
    
    return normalizeXZ(wishX, wishZ)
end
local function blendPlanarDir(currentX, currentZ, targetX, targetZ, factor)
    local blendedX = (currentX * (1 - factor)) + (targetX * factor)
    local blendedZ = (currentZ * (1 - factor)) + (targetZ * factor)
    local dirX, dirZ, dirLen = normalizeXZ(blendedX, blendedZ)
    if dirLen <= 0.001 then
        return targetX, targetZ
    end
    return dirX, dirZ
end
local function applyPlanarFriction(vx, vz, dt)
    local speed = math.sqrt((vx * vx) + (vz * vz))
    if speed < 0.001 then
        return 0, 0
    end

    local control = math.max(speed, SOURCE_STOP_SPEED)
    local drop = control * SOURCE_FRICTION * dt
    local newSpeed = math.max(speed - drop, 0)
    if newSpeed >= speed then
        return vx, vz
    end

    local scale = newSpeed / speed
    return vx * scale, vz * scale
end
local function acceleratePlanar(vx, vz, wishDirX, wishDirZ, wishSpeed, accel, dt, speedCap)
    if wishSpeed <= 0 then
        return vx, vz
    end

    local cappedWishSpeed = wishSpeed
    if speedCap and speedCap > 0 and cappedWishSpeed > speedCap then
        cappedWishSpeed = speedCap
    end

    local currentSpeed = (vx * wishDirX) + (vz * wishDirZ)
    local addSpeed = cappedWishSpeed - currentSpeed
    if addSpeed <= 0 then
        return vx, vz
    end

    local accelSpeed = accel * wishSpeed * dt
    if accelSpeed > addSpeed then
        accelSpeed = addSpeed
    end

    return vx + (wishDirX * accelSpeed), vz + (wishDirZ * accelSpeed)
end
local function getPlanarSpeedFromValues(vx, vz)
    return math.sqrt((vx * vx) + (vz * vz))
end
local function clampPlanarSpeed(vx, vz, maxSpeed)
    local speed = getPlanarSpeedFromValues(vx, vz)
    if speed <= maxSpeed or speed <= 0.001 then
        return vx, vz
    end

    local scale = maxSpeed / speed
    return vx * scale, vz * scale
end
local function writePlanarVelocity(hrp, vx, vz, vy)
    local curVel = hrp.AssemblyLinearVelocity or hrp.Velocity
    local finalY = vy or (curVel and (curVel.y or curVel.Y)) or 0
    
    local newVelocity = Vector3.new(vx, finalY, vz)
    
    pcall(function()
        if hrp.AssemblyLinearVelocity then
            hrp.AssemblyLinearVelocity = newVelocity
        else
            hrp.Velocity = newVelocity
        end
    end)
end
local function updateCFrameBhop(humanoid, hrp, dt)
    if not cfg.misc.cframeBhopEnabled then
        bunnyHopJumpLocked = false
        return
    end
    if not humanoid or not hrp then
        bunnyHopJumpLocked = false
        return
    end

    local holdingSpace = true
    if cfg.misc.cframeBhopRequireSpace then
        holdingSpace = isKeyHeld(0x20)
    end
    if not holdingSpace then
        bunnyHopJumpLocked = false
        return
    end

    local vel = hrp.AssemblyLinearVelocity or hrp.Velocity
    local vx, vz = getVectorXZ(vel)
    local currentVy = (vel and (vel.Y or vel.y)) or 0
    local dirX, dirZ, dirLen = getBunnyHopWishDir(humanoid)

    local deltaTime = math.max(dt or 0.01, 0.008)
    local grounded = isBunnyHopGrounded(humanoid)
    local maxSpeed = math.max(40, tonumber(cfg.misc.cframeBhopMaxSpeed) or 160)
    local shouldWrite = false
    local planarSpeed = getPlanarSpeedFromValues(vx, vz)

    local targetVy = nil 
    local now = os.clock()

    if grounded and not bunnyHopJumpLocked and (now - lastJumpTick > 0.15) then
        targetVy = tonumber(cfg.misc.cframeBhopJumpHeight) or 50
        bunnyHopJumpLocked = true
        lastJumpTick = now
        shouldWrite = true
    elseif not grounded then
        bunnyHopJumpLocked = false
    end

    if dirLen > 0.001 then
        local moveDirX, moveDirZ = dirX, dirZ
        local currentDirX, currentDirZ, currentDirLen = normalizeXZ(vx, vz)
        if currentDirLen > 0.001 then
            local turnFactor = math.min(1, SOURCE_TURN_RATE * deltaTime)
            if grounded then
                turnFactor = math.min(1, turnFactor * 1.75)
            end
            moveDirX, moveDirZ = blendPlanarDir(currentDirX, currentDirZ, dirX, dirZ, turnFactor)
        end

        if grounded and not holdingSpace then
            vx, vz = applyPlanarFriction(vx, vz, deltaTime)
        end

        local desiredWishSpeed = math.max(planarSpeed, grounded and 26 or 20)
        local accel = grounded and SOURCE_GROUND_ACCEL or SOURCE_AIR_ACCEL
        vx, vz = acceleratePlanar(vx, vz, moveDirX, moveDirZ, desiredWishSpeed, accel, deltaTime)

        local gain = (grounded and SOURCE_GROUND_GAIN or SOURCE_AIR_GAIN) * deltaTime
        local newSpeed = math.min(maxSpeed, math.max(getPlanarSpeedFromValues(vx, vz), planarSpeed, grounded and 24 or 18) + gain)
        vx, vz = moveDirX * newSpeed, moveDirZ * newSpeed
        shouldWrite = true
    elseif grounded and not holdingSpace then
        vx, vz = applyPlanarFriction(vx, vz, deltaTime)
        shouldWrite = true
    elseif shouldWrite then
        local speed = getPlanarSpeedFromValues(vx, vz)
        if speed > maxSpeed then
            vx, vz = clampPlanarSpeed(vx, vz, maxSpeed)
        end
    end

    vx, vz = clampPlanarSpeed(vx, vz, maxSpeed)

    if shouldWrite then
        writePlanarVelocity(hrp, vx, vz, targetVy)
    end
end
