local function getPrimitive(part)
    local addr = part.Address
    if not addr or addr == 0 then return nil end
    local prim = memory_read("uintptr_t", addr + OFF_PRIMITIVE)
    if not prim or prim == 0 then return nil end
    return prim
end
local function writeRot(primAddr, r0, r1, r2, u0, u1, u2, b0, b1, b2)
    local base = primAddr + OFF_CFRAME
    memory_write("float", base + 0x00, r0)
    memory_write("float", base + 0x04, r1)
    memory_write("float", base + 0x08, r2)
    memory_write("float", base + 0x0C, u0)
    memory_write("float", base + 0x10, u1)
    memory_write("float", base + 0x14, u2)
    memory_write("float", base + 0x18, b0)
    memory_write("float", base + 0x1C, b1)
    memory_write("float", base + 0x20, b2)
end
local function setPitchYaw(primAddr, pitch, yaw)
    local cy = math.cos(yaw)
    local sy = math.sin(yaw)
    local cp = math.cos(pitch)
    local sp = math.sin(pitch)
    writeRot(primAddr, cy, 0, -sy, sy * sp, cp, cy * sp, sy * cp, -sp, cy * cp)
end
local function getCamLookYaw()
    local cam = workspace.CurrentCamera
    if not cam then return 0 end
    local camAddr = cam.Address
    if not camAddr or camAddr == 0 then return 0 end
    local bx = memory_read("float", camAddr + 0xF8 + 0x18)
    local bz = memory_read("float", camAddr + 0xF8 + 0x20)
    return math.atan2(-bx, -bz)
end
