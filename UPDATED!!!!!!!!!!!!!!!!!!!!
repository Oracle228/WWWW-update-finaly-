                        local pVal = (pPing and memory_read("double", pPing.Address + 0xC8)) or (pPing and pPing:GetValue()) or 0
                        local dVal = (dPing and memory_read("double", dPing.Address + 0xC8)) or (dPing and dPing:GetValue()) or 0
                        if pVal == 0 then pVal = player:GetNetworkPing() * 1000 end
