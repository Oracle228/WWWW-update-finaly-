local function refreshTarget()
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local myHRP = getHRP(LocalPlayer)
    if not myHRP then targetPlayer = nil return end
    local myPos = myHRP.Position
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name ~= LocalPlayer.Name and isAlive(p) then
            local onTeam = cfg.player.isTeamCheck and p.Team == LocalPlayer.Team
            if not onTeam then
                local hrp = getHRP(p)
                if hrp then
                    local dist = math.huge
                    if cfg.player.targetMode == "Closest" then
                        dist = (hrp.Position - myPos).Magnitude
                    end
                    if dist and dist < bestDist then
                        bestDist, best = dist, p
                    end
                end
            end
        end
    end
    targetPlayer = best
end
