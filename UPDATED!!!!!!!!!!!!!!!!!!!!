local function isBunnyHopGrounded(humanoid)
    if not humanoid then return false end
    local char = humanoid.Parent
    if not char then return false end
    local hrp = nil
    pcall(function() hrp = char:FindFirstChild("HumanoidRootPart") end)
    if not hrp then return false end

    local vy = hrp.Velocity.y or hrp.Velocity.Y or 0
    if vy > 1.5 then return false end

    local ok, material = pcall(function() return humanoid.FloorMaterial end)
    if ok and material ~= nil then
        local materialName = tostring(material)
        if materialName ~= "Air" and materialName ~= "Enum.Material.Air" and materialName ~= "" then
            return true
        end
    end

    local floorMat = nil
    pcall(function()
        local addr = humanoid.Address
        if addr and addr ~= 0 then
            floorMat = memory_read("int", addr + OFF_HUMANOID_FLOOR_MATERIAL)
        end
    end)
    if type(floorMat) == "number" then
        if floorMat ~= FLOOR_MATERIAL_AIR then
            return true
        end
    end

    return false
end
