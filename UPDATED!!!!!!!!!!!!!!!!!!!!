                local uSegs = math.floor(cfg.visuals.NimbSegments)
                local vSegs = math.floor(cfg.visuals.NimbTubeSegments or 8)
                
                local topPos = head.Position + Vector3.new(0, cfg.visuals.NimbHeight, 0)
                
                local lx, ly, lz = 0.5, 1.0, 0.5
                local lLen = math.sqrt(lx*lx + ly*ly + lz*lz)
                lx, ly, lz = lx/lLen, ly/lLen, lz/lLen
                
                local function getTorusPtAndNorm(uA, vA)
                    local uC, uS = math.cos(uA), math.sin(uA)
                    local vC, vS = math.cos(vA), math.sin(vA)
                    
                    local x = (R + rTube * vC) * uC
                    local y = rTube * vS
                    local z = (R + rTube * vC) * uS
                    
                    local p = topPos + Vector3.new(x, y, z)
                    local nx = vC * uC
                    local ny = vS
                    local nz = vC * uS
                    
                    return p, {nx, ny, nz}
                end
                
                local tIdx = 1
                local maxTris = uSegs * vSegs * 2
                
                for i = 0, uSegs - 1 do
                    local u1 = (i / uSegs) * math.pi * 2
